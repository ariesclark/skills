session_mktemp() {
	local session_id=${session_id:-${CLAUDE_CODE_SESSION_ID:-}}

	if [[ -z "$session_id" ]]; then
		echo 'session_mktemp: session_id is empty; expected a session_id global or CLAUDE_CODE_SESSION_ID in the environment' >&2
		return 1
	fi

	mktemp -dt "${session_id//-/}-$1-XXXXXX"
}

session_cleanup() {
	[[ -n "${session_id:-}" ]] || return 0
	rm -rf "${TMPDIR:-/tmp}/${session_id//-/}-$1"-*
}
