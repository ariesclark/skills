#!/usr/bin/env bash

directory="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

context=$(cat << 'EOF'
These calls are always blocked and will fail; never attempt them:
- `WebFetch` of any github.com URL
- `curl` or `wget` of any github.com URL
- `gh api repos/<owner>/<repo>/contents/...` reads

Instead:
- Repository files or gists: run `bash {directory}/clone-temporarily <owner>/<repo> | <gist-id>`, read the printed clone (removed at session end). File at a ref: `git show <ref>:<path>`.
- PRs: `gh pr view <n> --repo <owner>/<repo> --comments`, `gh pr diff <n>`. Issues: `gh issue view <n> --comments`. Releases: `gh release view <tag>`. CI runs: `gh run view <id> --log-failed`.
- Search: `gh search <code|issues|prs|repos> <query>`. Other API reads: `gh api <path>`.
EOF
)

printf '%s\n' "${context//'{directory}'/$directory}"
