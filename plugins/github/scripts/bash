#!/usr/bin/env bash

directory="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$directory/core/url"

input=$(cat)
command=$(jq -r '.tool_input.command // empty' <<< "$input")

[[ "$command" == *curl* || "$command" == *wget* ]] || exit 0
command -v shfmt > /dev/null || exit 0

urls=$(shfmt --to-json <<< "$command" 2> /dev/null | jq -r -L "$directory/core" -f "$directory/bash.jq")

while IFS= read -r candidate; do
	[[ -n "$candidate" ]] || continue

	parse_url candidate "$candidate"
	host_is "$candidate_host" github.com githubusercontent.com \
		|| continue

	jq --arg url "$candidate" '.tool_input.url = $url' <<< "$input" \
		| bash "$directory/webfetch"
	exit
done <<< "$urls"

exit 0
