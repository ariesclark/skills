#!/usr/bin/env bash

directory="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$directory/core/mktemp"

usage='usage: clone-temporarily <owner>/<repo> | <gist_id>'
target=${1:?$usage}

if [[ "$target" =~ ^[0-9a-f]{20,}$ ]]; then
	clone=(gh gist clone "$target")
	flags=(-q)
elif [[ "$target" =~ ^[^/]+/[^/]+$ ]]; then
	clone=(gh repo clone "$target")
	flags=(--filter=blob:none -q)
else
	echo "$usage" >&2
	exit 1
fi

destination=$(session_mktemp "github-${target//\//-}") || exit 1

if ! "${clone[@]}" "$destination" -- "${flags[@]}" 2> /dev/null; then
	rm -rf "$destination"
	echo "$target could not be cloned (private, nonexistent, or inaccessible)" >&2
	exit 2
fi

printf '%s\n' "$destination"
