# Kagi fetches a page from its own network, so it reaches only public hosts.
# Local and private addresses stay with the caller, as do the hosts another
# plugin or the harness already claims.
reachable_by_kagi() {
	local host=${1,,}

	case "$host" in
		localhost | *.localhost | *.local | *.test | *.internal) return 1 ;;
		127.* | 0.0.0.0 | 10.* | 192.168.* | 169.254.*) return 1 ;;
		172.1[6-9].* | 172.2[0-9].* | 172.3[01].*) return 1 ;;
		"[::1]" | ::1) return 1 ;;
	esac

	# github.com fetches are redirected to a local clone by the github plugin,
	# and claude.ai artifacts are readable only through WebFetch's own login.
	host_is "$host" github.com githubusercontent.com claude.ai \
		&& return 1

	return 0
}
